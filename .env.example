# Google Sheet
SPREADSHEET_ID=YOUR_SPREADSHEET_ID
SHEET_NAME=YOUR_SHEET_NAME
RANGE=A1:A89

# ElevenLabs
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY
ELEVENLABS_VOICE_IDS=VOICE_ID_1,VOICE_ID_2
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Sentence Shadowing
REPEAT_COUNT=4
DEFAULT_SENTENCE_PAUSE=2
PAUSE_SECONDS=2

# Group Shadowing
GROUP_SIZE=5
GROUP_REVIEW_MODES=full,short
GROUP_FULL_REPEAT_COUNT=4
GROUP_FULL_REPEAT_PAUSE=2
GROUP_SHORT_REPEAT_COUNT=4
GROUP_SHORT_REPEAT_PAUSE=2

# Audio
AUDIO_SPEED=1.0
OUTPUT_SPEED_FOLDER=true

# 최종 결과 복사 디렉토리
GOOGLE_DRIVE_DIR=G:\내 드라이브\영어연습